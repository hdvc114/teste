<!DOCTYPE html>
<html lang="pt-BR">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Marketing - Projects</title>
  <link rel="stylesheet" href="/style.css">
</head>
<body>
  <header>
    <div class="header-inner">
      <a href="/" class="logo small">
        <span class="logo-icon">&#9670;</span>
        <span>Projects</span>
      </a>
      <span class="badge marketing-badge">Marketing</span>
    </div>
  </header>

  <main class="marketing-page">
    <h1>Projetos Recebidos</h1>

    <% if (unresponded.length > 0) { %>
      <div class="section-header">
        <h2 class="section-title"><span class="section-badge unanswered-badge"><%= unresponded.length %></span> Aguardando resposta</h2>
      </div>
      <div class="projects-grid">
        <% unresponded.forEach(project => { %>
          <%- include('_projectCard', { project, responsesByProject }) %>
        <% }); %>
      </div>
    <% } %>

    <% if (responded.length > 0) { %>
      <div class="section-header">
        <h2 class="section-title"><span class="section-badge answered-badge"><%= responded.length %></span> Respondidos</h2>
      </div>
      <div class="projects-grid">
        <% responded.forEach(project => { %>
          <%- include('_projectCard', { project, responsesByProject }) %>
        <% }); %>
      </div>
    <% } %>

    <% if (projects.length === 0) { %>
      <p class="empty-state">Nenhum projeto recebido ainda.</p>
    <% } %>
  </main>
</body>
</html>
