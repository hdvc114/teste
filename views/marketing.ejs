<!DOCTYPE html>
<html lang="pt-BR">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Marketing - Azul Projects</title>
  <link rel="stylesheet" href="/style.css">
</head>
<body>
  <header>
    <div class="header-inner">
      <a href="/" class="logo small">
        <span class="logo-icon">&#9670;</span>
        <span>Azul Projects</span>
      </a>
      <span class="badge marketing-badge">Marketing</span>
    </div>
  </header>

  <main class="marketing-page">
    <h1>Projetos Recebidos</h1>

    <div class="section-tabs">
      <a href="#unresponded" class="tab-link <%= unresponded.length > 0 ? 'active' : '' %>">
        <span class="tab-badge red"><%= unresponded.length %></span> Aguardando
      </a>
      <a href="#waiting" class="tab-link <%= waitingCreator.length > 0 && unresponded.length === 0 ? 'active' : '' %>">
        <span class="tab-badge yellow"><%= waitingCreator.length %></span> Respondidos
      </a>
      <a href="#replied" class="tab-link <%= creatorReplied.length > 0 && unresponded.length === 0 && waitingCreator.length === 0 ? 'active' : '' %>">
        <span class="tab-badge green"><%= creatorReplied.length %></span> Funcionário respondeu
      </a>
    </div>

    <% if (unresponded.length > 0) { %>
      <div id="unresponded" class="section-block">
        <div class="section-header">
          <h2 class="section-title"><span class="section-badge red-badge"><%= unresponded.length %></span> Aguardando resposta</h2>
          <p class="section-desc">Você ainda não respondeu a estes projetos.</p>
        </div>
        <div class="projects-grid">
          <% unresponded.forEach(project => { %>
            <%- include('_projectCard', { project, responsesByProject }) %>
          <% }); %>
        </div>
      </div>
    <% } %>

    <% if (waitingCreator.length > 0) { %>
      <div id="waiting" class="section-block">
        <div class="section-header">
          <h2 class="section-title"><span class="section-badge yellow-badge"><%= waitingCreator.length %></span> Aguardando resposta do Funcionário</h2>
          <p class="section-desc">Você respondeu, mas o funcionário ainda não respondeu.</p>
        </div>
        <div class="projects-grid">
          <% waitingCreator.forEach(project => { %>
            <%- include('_projectCard', { project, responsesByProject }) %>
          <% }); %>
        </div>
      </div>
    <% } %>

    <% if (creatorReplied.length > 0) { %>
      <div id="replied" class="section-block">
        <div class="section-header">
          <h2 class="section-title"><span class="section-badge green-badge"><%= creatorReplied.length %></span> Funcionário respondeu</h2>
          <p class="section-desc">O funcionário respondeu à sua mensagem. Veja o que ele disse.</p>
        </div>
        <div class="projects-grid">
          <% creatorReplied.forEach(project => { %>
            <%- include('_projectCard', { project, responsesByProject }) %>
          <% }); %>
        </div>
      </div>
    <% } %>

    <% if (projects.length === 0) { %>
      <p class="empty-state">Nenhum projeto recebido ainda.</p>
    <% } %>
  </main>
</body>
</html>
