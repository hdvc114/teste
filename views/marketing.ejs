<!DOCTYPE html>
<html lang="pt-BR">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Marketing - Projects</title>
  <link rel="stylesheet" href="/style.css">
</head>
<body>
  <header>
    <div class="header-inner">
      <a href="/" class="logo small">
        <span class="logo-icon">&#9670;</span>
        <span>Projects</span>
      </a>
      <span class="badge marketing-badge">Marketing</span>
    </div>
  </header>

  <main class="marketing-page">
    <h1>Projetos Recebidos</h1>
    <% if (projects.length === 0) { %>
      <p class="empty-state">Nenhum projeto recebido ainda.</p>
    <% } else { %>
      <div class="projects-grid">
        <% projects.forEach(project => { %>
          <div class="project-card">
            <div class="project-header">
              <h2><%= project.title %></h2>
              <span class="status <%= project.status %>"><%= project.status %></span>
            </div>
            <p class="project-desc"><%= project.description %></p>
            <div class="project-meta">
              <span><strong>Por:</strong> <%= project.creator_name %></span>
              <span><strong>Email:</strong> <%= project.creator_email %></span>
              <span><strong>Data:</strong> <%= new Date(project.created_at).toLocaleDateString('pt-BR') %></span>
            </div>

            <% if (project.conversation_messages && project.conversation_messages.length > 0) { %>
              <details class="conversation-details">
                <summary>Ver conversa do cliente</summary>
                <div class="conversation-log">
                  <% project.conversation_messages.forEach(msg => { %>
                    <div class="conv-msg <%= msg.role %>">
                      <strong><%= msg.role === 'ai' ? 'AI' : 'Cliente' %>:</strong>
                      <span><%= msg.content %></span>
                    </div>
                  <% }); %>
                </div>
              </details>
            <% } %>

            <details class="response-details">
              <summary>Responder</summary>
              <form action="/marketing/respond/<%= project.id %>" method="POST" class="response-form">
                <textarea name="message" rows="3" placeholder="Escreva sua resposta..." required></textarea>
                <button type="submit">Enviar Resposta</button>
              </form>
            </details>

            <% if (responsesByProject[project.id]) { %>
              <div class="responses">
                <h4>Respostas enviadas:</h4>
                <% responsesByProject[project.id].forEach(resp => { %>
                  <div class="response-item">
                    <p><%= resp.message %></p>
                    <small><%= new Date(resp.created_at).toLocaleDateString('pt-BR') %></small>
                  </div>
                <% }); %>
              </div>
            <% } %>
          </div>
        <% }); %>
      </div>
    <% } %>
  </main>
</body>
</html>
